#!/bin/bash
# mac-bootstrap: 新規Macの初期セットアップ
# 使い方: curl等でこのスクリプトを取得して実行、またはDropbox同期後に実行
#   bash ~/Dropbox/System/bin/mac-bootstrap
#
# 前提: Safariからターミナルを開ける状態

set -e

echo "=== Mac Bootstrap ==="
echo "ユーザー: $(whoami)"
echo "ホーム: $HOME"
echo ""

# 1. Homebrew
if ! command -v brew &>/dev/null; then
  echo ">>> Homebrewをインストール..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  # .zprofile にbrewのPATHを追加（ユーザー名に依存しない形）
  echo >> "$HOME/.zprofile"
  echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> "$HOME/.zprofile"
  eval "$(/opt/homebrew/bin/brew shellenv)"
else
  echo ">>> Homebrew: already installed"
fi

# 2. Dropbox
if [ ! -d "$HOME/Dropbox" ]; then
  echo ">>> Dropboxをインストール..."
  brew install --cask dropbox
  echo ""
  echo "⚠️  Dropboxを起動してログインしてください。"
  echo "   1. Dropbox.app を開く"
  echo "   2. ログイン（メール/パスワード）"
  echo "   3. アクセシビリティを許可"
  echo "   4. すべて同期する"
  echo "   5. 詳細設定 → Dropbox on File Provider のオプトアウトをcheck"
  echo "   6. ~/Dropbox/System を右クリック → オフラインアクセスを許可"
  echo ""
  echo "同期が完了したらもう一度このスクリプトを実行してください。"
  open /Applications/Dropbox.app
  exit 0
else
  echo ">>> Dropbox: already synced"
fi

# 3. Dropbox/System が同期されているか確認
if [ ! -d "$HOME/Dropbox/System/bin" ]; then
  echo "⚠️  ~/Dropbox/System がまだ同期されていません。"
  echo "   Dropboxの同期を待ってから再実行してください。"
  echo "   ~/Dropbox/System を右クリック → オフラインアクセスを許可"
  exit 1
fi

# 4. mac-configure (シンボリンク作成 + defaults設定)
echo ">>> mac-configure を実行..."
ruby "$HOME/Dropbox/System/bin/mac-configure"

# 5. brew-setup (パッケージインストール)
echo ">>> brew-setup を実行..."
python3 "$HOME/Dropbox/System/bin/brew-setup"

# 6. SSH鍵の設定
if ! ls "$HOME/.ssh/id_ed25519"* &>/dev/null; then
  echo ""
  echo "⚠️  SSH鍵がありません。以下を実行してください:"
  echo "   ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -N \"\""
fi

echo ""
echo "=== Bootstrap 完了 ==="
echo ""
echo "残りの手動設定:"
echo "  - システム設定 → 一般 → 情報 → コンピュータ名を設定"
echo "  - システム設定 → ディスプレイ → スペースを拡大、Night Shift 18:00-9:00"
echo "  - システム設定 → Touch IDとパスワード → Apple Watch"
echo "  - システム設定 → インターネットアカウント → Googleアカウント追加"
echo "  - メモ.app → 設定 → デフォルトのフォントサイズを最大に"
echo "  - アクセシビリティ → ポインタ → サイズを大きくする"
