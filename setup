install_packages() {
  log "Setting up Homebrew packages..."

  # Xcode CLI tools
  if ! xcode-select -p &>/dev/null; then
    log "Installing Xcode Command Line Tools..."
    xcode-select --install
    read -rp "Press Enter after Xcode CLT installation completes..."
  fi

  local tmpfile
  tmpfile=$(mktemp /tmp/Brewfile.XXXXXX)
  echo "$BREWFILE_BASE" > "$tmpfile"

  if [ "$INSTALL_ADMIN" = 1 ]; then
    sudo -v
    echo "$BREWFILE_ADMIN" >> "$tmpfile"
  fi
  if [ "$INSTALL_EXTENDED" = 1 ]; then
    echo "$BREWFILE_EXTENDED" >> "$tmpfile"
  fi

  brew bundle --file="$tmpfile" || true
  rm -f "$tmpfile"

  # iPad apps
  if [ ! -d "/Applications/SwitchBot.app/WrappedBundle" ]; then
    echo "  SwitchBot: not installed, opening App Store..."
    open "macappstore://apps.apple.com/app/id1087374760"
  fi

  brew cleanup
  log "Packages done"
}

# ============================================================ 14. Computer name

set_computer_name() {
  local current
  current=$(scutil --get ComputerName 2>/dev/null) || current=""
  if [ -n "$current" ] && [ "$current" != "$(whoami)のMacBook Pro" ] && [ "$current" != "MacBook Pro" ]; then
    echo "  Computer name: $current (already set)"
    return
  fi
  echo ""
  read -rp "  コンピュータ名を入力 (空欄でスキップ): " name
  if [ -n "$name" ]; then
    scutil --set ComputerName "$name"
    scutil --set LocalHostName "$name"
    scutil --set HostName "$name"
    echo "  Computer name set to: $name"
  fi
}

# ============================================================ Main

main() {
  echo "=== Mac Setup ==="
  echo "User: $(whoami) | Host: $(hostname -s)"
  echo ""

  # Parse options: setup [-a] [-x] [-f]
  INSTALL_ADMIN=0
  INSTALL_EXTENDED=0
  RUN_FULL=0
  while getopts "axf" opt; do
    case $opt in
      a) INSTALL_ADMIN=1 ;;
      x) INSTALL_EXTENDED=1 ;;
      f) RUN_FULL=1 ;;
      *) echo "Usage: $0 [-a] [-x] [-f]"; exit 1 ;;
    esac
  done

  # Phase 1: Dropbox不要（新Macでも即実行可能）
  install_homebrew
  install_packages
  set_macos_defaults
  set_app_defaults
  set_keyboard
  set_keyboard_maestro
  set_computer_name
  configure_dock
  set_wallpaper_black
  add_login_items

  # Phase 2: Dropbox同期後（未同期ならスキップ）
  install_dropbox
  create_symlinks

  if [ "$RUN_FULL" = 1 ]; then
    set_thunderbird_prefs
    check_stylus_import
  fi

  # SSH鍵の確認
  if ! ls "$HOME/.ssh/id_ed25519"* &>/dev/null; then
    echo ""
    echo "  SSH鍵がありません。以下を実行してください:"
    echo "    ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -N \"\""
  fi

  echo ""
  echo "=== Setup complete ==="
  echo ""
  if ! dropbox_available; then
    echo "  Dropbox同期後に再度 setup を実行してください（シンボリックリンク作成）"
    echo ""
  fi
  echo "残りの手動設定:"
  echo "  - システム設定 → ディスプレイ → スペースを拡大"
  echo "  - システム設定 → ディスプレイ → Night Shift 18:00-9:00"
  echo "  - システム設定 → Touch IDとパスワード → Apple Watch"
  echo "  - システム設定 → インターネットアカウント → Googleアカウント追加"
  echo "  - アクセシビリティ → ポインタ → サイズを大きくする"
}

main "$@"
