#!/bin/bash
# setup-stage1: 新Mac物理操作の最小スクリプト（idempotent）
#
# 目的: ホスト名を hoshilab に設定する。
#
# 前提: 「リモートログイン (SSH)」はあらかじめ GUI で有効化しておくこと。
#       システム設定 → 一般 → 共有 → リモートログイン を ON
#
#       macOS Tahoe 以降は systemsetup -setremotelogin on が
#       TCC/プライバシー要件で必ずしも反映されないため、
#       SSH 有効化は GUI に分離した（このスクリプトでは触らない）。
#
# Usage:
#   curl -fsSL rojilab.github.io/dotfiles/setup-stage1 -o setup-stage1
#   bash setup-stage1
#
# 別ホスト名にしたい場合:
#   HOSTNAME_TARGET=othername bash setup-stage1
#
# 冪等: 何度実行しても結果は同じ。既に設定済みならスキップ表示のみ。

set -e

HOSTNAME_TARGET="${HOSTNAME_TARGET:-hoshilab}"

echo "=== setup-stage1: Hostname (target: $HOSTNAME_TARGET) ==="

# ホスト名設定 (3種類: ComputerName / LocalHostName / HostName)
set_hostname() {
    local key="$1"
    local current
    current=$(scutil --get "$key" 2>/dev/null || echo "")
    if [ "$current" = "$HOSTNAME_TARGET" ]; then
        echo "  $key: $current (already set)"
    else
        echo "→ $key を $HOSTNAME_TARGET に設定 (was: ${current:-<empty>})..."
        sudo scutil --set "$key" "$HOSTNAME_TARGET"
    fi
}
set_hostname ComputerName
set_hostname LocalHostName
set_hostname HostName

# 確認
echo ""
echo "=== 確認 ==="
echo "ComputerName : $(scutil --get ComputerName)"
echo "LocalHostName: $(scutil --get LocalHostName)"
echo "HostName     : $(scutil --get HostName)"

# SSH の状態を情報として表示（有効化はしない）
echo ""
ssh_status=$(sudo systemsetup -getremotelogin 2>/dev/null | awk '{print $NF}')
echo "Remote Login (SSH): $ssh_status"

# IPアドレス
echo ""
echo "このマシンの IP アドレス:"
for iface in en0 en1 en2 en3; do
    ip=$(ifconfig "$iface" 2>/dev/null | awk '/inet /{print $2}')
    [ -n "$ip" ] && echo "  $iface: $ip"
done

echo ""
if [ "$ssh_status" != "On" ]; then
    echo "⚠ SSH が無効です。"
    echo "  システム設定 → 一般 → 共有 → リモートログイン を ON にしてください。"
    echo "  (このスクリプトは SSH を有効化しません)"
else
    echo "✓ setup-stage1 完了。別マシンから下記で接続できるはず:"
    echo "  ssh $(whoami)@<上記の IP>"
fi
