#!/bin/bash
# setup-stage1: 新Mac物理操作の最小スクリプト（idempotent）
#
# 目的: SSH (Remote Login) を有効化し、ホスト名を hoshilab に設定する。
#       これだけ走らせれば、以降は別マシンから ssh 越しに setup (stage2) を
#       進められる。新Mac の物理画面の前で行う作業はこれだけ。
#
# Usage:
#   curl -fsSL rojilab.github.io/dotfiles/setup-stage1 > setup-stage1
#   bash setup-stage1
#
# 別ホスト名にしたい場合:
#   HOSTNAME_TARGET=othername bash setup-stage1
#
# 冪等: 何度実行しても結果は同じ。既に設定済みならスキップ表示のみ。

set -e

HOSTNAME_TARGET="${HOSTNAME_TARGET:-hoshilab}"

echo "=== setup-stage1: SSH + Hostname (target: $HOSTNAME_TARGET) ==="

# 1. SSH (Remote Login) 有効化
current_ssh=$(sudo systemsetup -getremotelogin 2>/dev/null | awk '{print $NF}')
if [ "$current_ssh" = "On" ]; then
    echo "  SSH (Remote Login): On (already enabled)"
else
    echo "→ SSH (Remote Login) を有効化..."
    sudo systemsetup -setremotelogin on
fi

# 2. ホスト名設定 (3種類: ComputerName / LocalHostName / HostName)
set_hostname() {
    local key="$1"
    local current
    current=$(scutil --get "$key" 2>/dev/null || echo "")
    if [ "$current" = "$HOSTNAME_TARGET" ]; then
        echo "  $key: $current (already set)"
    else
        echo "→ $key を $HOSTNAME_TARGET に設定 (was: ${current:-<empty>})..."
        sudo scutil --set "$key" "$HOSTNAME_TARGET"
    fi
}
set_hostname ComputerName
set_hostname LocalHostName
set_hostname HostName

# 3. 確認
echo ""
echo "=== 確認 ==="
echo "ComputerName : $(scutil --get ComputerName)"
echo "LocalHostName: $(scutil --get LocalHostName)"
echo "HostName     : $(scutil --get HostName)"
sudo systemsetup -getremotelogin

echo ""
echo "ローカルIP:"
for iface in en0 en1 en2; do
    ip=$(ifconfig "$iface" 2>/dev/null | awk '/inet /{print $2}')
    [ -n "$ip" ] && echo "  $iface: $ip"
done

echo ""
echo "✓ setup-stage1 完了。別マシンから下記で接続できるはず:"
echo "  ssh $(whoami)@${HOSTNAME_TARGET}.local"
echo ""
echo "次のステップ (別マシンから ssh で入った後):"
echo "  curl -fsSL rojilab.github.io/dotfiles/setup > setup"
echo "  bash setup"
